# GNSIS talks to LLMs through OpenRouter (an OpenAI-compatible gateway).
# Copy this file to `.env` and fill in your key. The CLI loads `.env`
# automatically.

OPENROUTER_API_KEY=

# Optional overrides ---------------------------------------------------------
# Any OpenRouter model slug works. Default routes to the latest Claude Opus.
# OPENROUTER_MODEL=anthropic/claude-opus-4.8
#
# Point at any OpenAI-compatible endpoint (e.g. a local gateway) if you like.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
