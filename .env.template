# GNSIS talks to LLMs through OpenRouter (an OpenAI-compatible gateway).
# Copy this file to `.env` and fill in your key. The CLI loads `.env`
# automatically.

OPENROUTER_API_KEY=

# Optional overrides ---------------------------------------------------------
# Any OpenRouter model slug works. Default routes to the latest Claude Opus.
# OPENROUTER_MODEL=anthropic/claude-opus-4.8
#
# Point at any OpenAI-compatible endpoint (e.g. a local gateway) if you like.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================================================
# Service layer (Railway: FastAPI API + Celery worker). Only needed to run the
# job service — the GNSIS core/CLI ignores all of these.
# ============================================================================

# Required ------------------------------------------------------------------
# Postgres (durable store) and Redis (Celery broker/result backend). On Railway,
# reference the plugins, e.g. DATABASE_URL=${{Postgres.DATABASE_URL}}
# DATABASE_URL=postgresql://user:pass@host:5432/db
# REDIS_URL=redis://host:6379/0

# Engine #1 — the Claude Agent SDK talks to Anthropic directly (NOT OpenRouter).
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub App — used only by the worker's publish step, after human approval.
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...multiline PEM...\n-----END RSA PRIVATE KEY-----"

# Optional ------------------------------------------------------------------
# GNSIS_DEFAULT_ENGINE=claude
# GNSIS_DEFAULT_BASE_BRANCH=main
# GNSIS_WORKSPACE_ROOT=/tmp/gnsis-workspaces
# GNSIS_WORKER_CONCURRENCY=2
# GNSIS_API_KEY=                 # if set, API requires: Authorization: Bearer <key>
# GNSIS_ALLOWED_REPOS=owner/repo1,owner/repo2   # allowlist; empty = allow any
# CELERY_BROKER_URL=             # defaults to REDIS_URL
# CELERY_RESULT_BACKEND=         # defaults to REDIS_URL
