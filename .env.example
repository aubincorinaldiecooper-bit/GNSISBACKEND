# GNSIS backend (FastAPI API + Celery worker) — copy to .env for local dev.
# Placeholders only — never commit real credentials.

# ============================================================================
# Required — Postgres and Redis
# ============================================================================
DATABASE_URL=postgresql://user:pass@host:5432/db
REDIS_URL=redis://host:6379/0

# ============================================================================
# Better Auth JWT bridge — how the backend authenticates end users.
# BETTER_AUTH_JWKS_URL is the auth service's published JWKS endpoint, e.g.
# https://<auth-service-domain>/api/auth/jwks
# ============================================================================
BETTER_AUTH_JWKS_URL=https://auth.example.com/api/auth/jwks
BETTER_AUTH_ISSUER=https://auth.example.com
BETTER_AUTH_AUDIENCE=gnsis-api

# Server-to-server call to the auth service (installation ownership check).
GNSIS_AUTH_INTERNAL_URL=https://auth.example.com
GNSIS_AUTH_INTERNAL_SECRET=replace-with-a-long-random-shared-secret

# ============================================================================
# GitHub App — platform-owned credentials. Used to mint short-lived
# installation tokens per run (cloning, pushing, opening PRs).
# ============================================================================
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...multiline PEM...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_SLUG=genesis
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret

# Deprecated fallback — only used for legacy/internal runs with no repository
# record. User runs resolve their own installation per job.
# GITHUB_APP_INSTALLATION_ID=12345678

# The deployed frontend origin — used for CORS and as the default in
# GNSIS_CORS_ORIGINS if you don't set that separately.
GNSIS_FRONTEND_URL=https://app.example.com

# ============================================================================
# Optional
# ============================================================================
# ANTHROPIC_API_KEY=sk-ant-...        # engine "claude" only
# OPENROUTER_API_KEY=sk-or-...        # engine "gnsis" (native, model-agnostic)
# GNSIS_DEFAULT_ENGINE=claude
# GNSIS_DEFAULT_BASE_BRANCH=main
# GNSIS_WORKSPACE_ROOT=/tmp/gnsis-workspaces
# GNSIS_WORKER_CONCURRENCY=2
# GNSIS_API_KEY=                      # internal/emergency path only — NOT an end-user identity
# GNSIS_ALLOWED_REPOS=owner/repo1,owner/repo2   # only applies to the internal /internal/jobs path
# GNSIS_CORS_ORIGINS=https://app.example.com
# CELERY_BROKER_URL=                  # defaults to REDIS_URL
# CELERY_RESULT_BACKEND=              # defaults to REDIS_URL
# GNSIS_MEMORY=postgres
# GNSIS_SANDBOX=none
