# GNSIS backend (FastAPI API + Celery worker) — copy to .env for local dev.
# Placeholders only — never commit real credentials.

# ============================================================================
# Required — Postgres and Redis
# ============================================================================
DATABASE_URL=postgresql://user:pass@host:5432/db
REDIS_URL=redis://host:6379/0

# ============================================================================
# Better Auth JWT bridge — how the backend authenticates end users.
# BETTER_AUTH_JWKS_URL is the auth service's published JWKS endpoint, e.g.
# https://<auth-service-domain>/api/auth/jwks
# ============================================================================
BETTER_AUTH_JWKS_URL=https://auth.example.com/api/auth/jwks
BETTER_AUTH_ISSUER=https://auth.example.com
BETTER_AUTH_AUDIENCE=gnsis-api

# Server-to-server call to the auth service (installation ownership check).
GNSIS_AUTH_INTERNAL_URL=https://auth.example.com
GNSIS_AUTH_INTERNAL_SECRET=replace-with-a-long-random-shared-secret

# ============================================================================
# GitHub App — platform-owned credentials. Used to mint short-lived
# installation tokens per run (cloning, pushing, opening PRs).
# ============================================================================
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...multiline PEM...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_SLUG=genesis
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret

# Deprecated fallback — only used for legacy/internal runs with no repository
# record. User runs resolve their own installation per job.
# GITHUB_APP_INSTALLATION_ID=12345678

# The deployed frontend origin — used for CORS and as the default in
# GNSIS_CORS_ORIGINS if you don't set that separately.
GNSIS_FRONTEND_URL=https://app.example.com

# ============================================================================
# Public-beta remote execution (GitHub Actions) — REQUIRED in production.
# Every user job executes ONLY through the fixed workflow in the private
# executor repo. The provider is fixed here and is never read from API/frontend
# job input. Missing/invalid config prevents job creation and (in production)
# fails startup.
# ============================================================================
GNSIS_EXECUTION_PROVIDER=github_actions
GNSIS_PUBLIC_API_URL=https://meticulous-illumination-production-7414.up.railway.app
GNSIS_EXECUTOR_OWNER=aubincorinaldiecooper-bit
# NOTE: the real executor repo is "Gnsis-studio-" (trailing dash), not
# "gnsis-studio". OIDC pins the exact repository/workflow_ref, so this must match.
GNSIS_EXECUTOR_REPO=Gnsis-studio-
GNSIS_EXECUTOR_WORKFLOW=execute.yml
GNSIS_EXECUTOR_REF=main
GNSIS_EXECUTOR_OIDC_ISSUER=https://token.actions.githubusercontent.com
GNSIS_EXECUTOR_OIDC_AUDIENCE=https://api.gnsis.studio
# The exact commit SHA of the executor's default branch that is trusted to run.
GNSIS_EXECUTOR_TRUSTED_WORKFLOW_SHA=<full executor main commit SHA>

# TTLs / deadlines / size ceilings / budgets (defaults shown).
GNSIS_EXECUTOR_TOKEN_TTL_SECONDS=1800
GNSIS_RUN_TOKEN_TTL_SECONDS=1800
GNSIS_EXECUTOR_TIMEOUT_SECONDS=1800
GNSIS_EXECUTOR_SOURCE_MAX_BYTES=262144000
GNSIS_EXECUTOR_CALLBACK_MAX_BYTES=10485760
GNSIS_EXECUTOR_PATCH_MAX_BYTES=5242880
GNSIS_EXECUTOR_EVENT_MAX_BYTES=5242880
GNSIS_RUN_MAX_MODEL_CALLS=50
GNSIS_RUN_MAX_INPUT_TOKENS=500000
GNSIS_RUN_MAX_OUTPUT_TOKENS=100000
GNSIS_RUN_MAX_COST_USD=3.00
# Server-controlled model allowlist (comma-separated). Defaults to opus-4.8.
# GNSIS_RUN_ALLOWED_MODELS=anthropic/claude-opus-4.8
# Set per service so startup validation targets the right requirements.
# GNSIS_SERVICE_ROLE=api            # "api" (default) or "worker"

# ============================================================================
# Optional
# ============================================================================
# OPENROUTER_API_KEY=sk-or-...        # API service ONLY (the model gateway). NOT the worker.
# GNSIS_DEFAULT_ENGINE=gnsis
# GNSIS_DEFAULT_BASE_BRANCH=main
# GNSIS_WORKER_CONCURRENCY=2
# GNSIS_API_KEY=                      # internal/emergency path only — NOT an end-user identity
# GNSIS_ALLOWED_REPOS=owner/repo1,owner/repo2   # only applies to the internal /internal/jobs path
# GNSIS_CORS_ORIGINS=https://app.example.com
# CELERY_BROKER_URL=                  # defaults to REDIS_URL
# CELERY_RESULT_BACKEND=              # defaults to REDIS_URL
# GNSIS_MEMORY=postgres
#
# REMOVED from the user-job path (do not set for user jobs):
#   GNSIS_SANDBOX                     # no in-worker Docker execution anymore
#   GITHUB_APP_INSTALLATION_ID        # each job resolves its own installation
