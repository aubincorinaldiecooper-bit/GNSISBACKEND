# Sandbox image for GNSIS — runs the engine (model-written edits + tests) in an
# isolated, ephemeral container. Built and referenced by the Docker sandbox
# (GNSIS_SANDBOX=docker, GNSIS_SANDBOX_IMAGE).
#
# The Claude Agent SDK (Python) drives the Claude Code CLI under the hood, so the
# image needs Node.js + the CLI in addition to Python, git, and GNSIS.
#
#   docker build -f Dockerfile.sandbox -t gnsis-sandbox:latest .
FROM python:3.12-slim

# git for diffing/patching; node for the Claude Code CLI the SDK spawns.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g @anthropic-ai/claude-code \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . /app
RUN pip install --no-cache-dir -e ".[service]"

# Engine work runs as an unprivileged user against the mounted /work volume.
# (The worker also passes --user; this is a sane default if run standalone.)
RUN useradd -m -u 10001 sandbox && mkdir -p /work && chown sandbox:sandbox /work
USER sandbox
WORKDIR /work

ENTRYPOINT ["python", "-m", "gnsis.service.runner"]
